{
  "version": 2,
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "regions": ["iad1"],
  "rewrites": [
    {
      "source": "/((?!assets/|icon-only\\.png|logo-light\\.png|logo-dark\\.png|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
